{
  "schema_version": "1.0",
  "python_requires": ">=3.9",
  "scale": {
    "minimum": 0,
    "maximum": 6,
    "step": 0.5,
    "output_decimals": 1,
    "rounding": "ROUND_HALF_UP"
  },
  "dimensions": [
    {"id": "significance", "label": "Significance"},
    {"id": "novelty", "label": "Novelty"},
    {"id": "soundness", "label": "Technical Soundness"},
    {"id": "evidence", "label": "Evidence and Evaluation"},
    {"id": "clarity", "label": "Clarity"},
    {"id": "related_work", "label": "Related Work"},
    {"id": "reproducibility", "label": "Reproducibility"}
  ],
  "dimension_statuses": {
    "score_bearing": ["assessed", "missing_in_paper"],
    "unknown": ["unavailable_to_reviewer"],
    "excluded": ["not_applicable"]
  },
  "paper_types": {
    "theory": {
      "weights": {
        "significance": 0.15,
        "novelty": 0.20,
        "soundness": 0.30,
        "evidence": 0.10,
        "clarity": 0.10,
        "related_work": 0.08,
        "reproducibility": 0.07
      }
    },
    "model_method": {
      "weights": {
        "significance": 0.15,
        "novelty": 0.20,
        "soundness": 0.20,
        "evidence": 0.25,
        "clarity": 0.08,
        "related_work": 0.07,
        "reproducibility": 0.05
      }
    },
    "benchmark_resource": {
      "weights": {
        "significance": 0.20,
        "novelty": 0.12,
        "soundness": 0.15,
        "evidence": 0.25,
        "clarity": 0.08,
        "related_work": 0.08,
        "reproducibility": 0.12
      }
    },
    "application_driven": {
      "weights": {
        "significance": 0.20,
        "novelty": 0.15,
        "soundness": 0.20,
        "evidence": 0.20,
        "clarity": 0.10,
        "related_work": 0.07,
        "reproducibility": 0.08
      }
    }
  },
  "coverage": {
    "method": "weighted",
    "exclude_status": "not_applicable",
    "minimum_for_score": 0.60,
    "provisional_below": 0.80,
    "required_dimensions": ["significance", "novelty", "soundness"]
  },
  "gates": {
    "FATAL_VALIDITY": {
      "label": "Fatal validity failure",
      "cap": 1.0
    },
    "UNSUPPORTED_CENTRAL_CLAIM": {
      "label": "Unsupported central claim",
      "cap": 2.0
    },
    "CORE_NOVELTY_UNESTABLISHED": {
      "label": "Core novelty not established",
      "cap": 2.5
    },
    "DECISIVE_EVIDENCE_MISSING": {
      "label": "Decisive evidence missing",
      "cap": 2.5
    }
  },
  "rating_bins": [
    {"anchor": 0, "lower_bound": 0.0, "label": "Strong Reject"},
    {"anchor": 1, "lower_bound": 0.5, "label": "Reject"},
    {"anchor": 2, "lower_bound": 1.5, "label": "Weak Reject"},
    {"anchor": 3, "lower_bound": 2.5, "label": "Borderline"},
    {"anchor": 4, "lower_bound": 3.5, "label": "Weak Accept"},
    {"anchor": 5, "lower_bound": 4.5, "label": "Accept"},
    {"anchor": 6, "lower_bound": 5.5, "label": "Strong Accept"}
  ],
  "confidence": {
    "components": {
      "material": {"minimum": 0, "maximum": 2},
      "verification": {"minimum": 0, "maximum": 2},
      "domain_match": {"minimum": 0, "maximum": 1}
    },
    "material_caps": {
      "0": 1,
      "1": 3
    },
    "labels": {
      "0": "No Confidence",
      "1": "Very Low",
      "2": "Low",
      "3": "Medium",
      "4": "High",
      "5": "Very High"
    }
  }
}
